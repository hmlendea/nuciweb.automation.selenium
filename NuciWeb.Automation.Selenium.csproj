<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <RootNamespace>NuciWeb.Automation.Selenium</RootNamespace>
    <Version>1.0.2</Version>
    <Description>Selenium implementation for NuciWeb.Automation</Description>
    <Authors>Horațiu Mlendea</Authors>
    <Copyright>Copyright 2026 © Horațiu Mlendea</Copyright>
    <RepositoryUrl>https://github.com/hmlendea/nuciweb.automation.selenium</RepositoryUrl>
    <PackageLicenseExpression>GPL-3.0-or-later</PackageLicenseExpression>
    <PackageTags>Web Automation Selenium</PackageTags>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="NuciWeb" Version="4.0.0" />
    <PackageReference Include="NuciWeb.Automation" Version="1.0.0" />
    <PackageReference Include="NuciWeb.HTTP" Version="1.5.0" />
    <PackageReference Include="Selenium.Support" Version="4.5.1" />
    <PackageReference Include="Selenium.WebDriver" Version="4.5.1" />
  </ItemGroup>

</Project>
